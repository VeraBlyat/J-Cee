# Copia este archivo como ".env" y pon TUS datos de PostgreSQL.
# DATABASE_URL debe apuntar a la MISMA base de datos que usa el frontend.
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_base_de_datos
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# En local no hace falta. En producción contra Azure Database for
# PostgreSQL (u otro proveedor que exija SSL), poné DATABASE_SSL=true.
DATABASE_SSL=false
